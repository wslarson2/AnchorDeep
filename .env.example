# Copy to .env.local in each package — see package-specific .env.example files

# Shared
NODE_ENV=development

# API (api/.env)
DATABASE_URL="postgresql://postgres:dev@localhost:5432/anchordeep"
REDIS_URL="redis://localhost:6379"
AUTH0_DOMAIN="your-tenant.auth0.com"
AUTH0_AUDIENCE="https://api.anchordeep.com"
INTERNAL_API_KEY="change-me-32-char-hex-string-here"
PORT=3001

# Scraper (scraper/.env)
API_BASE_URL="http://localhost:3001"
INTERNAL_API_KEY="change-me-32-char-hex-string-here"
REDIS_URL="redis://localhost:6379"
PLAYWRIGHT_HEADLESS="true"
PROXY_URL=""

# App (app/.env)
VITE_API_URL="http://localhost:3001"
VITE_AUTH0_DOMAIN="your-tenant.auth0.com"
VITE_AUTH0_CLIENT_ID="your-auth0-client-id"
VITE_AUTH0_AUDIENCE="https://api.anchordeep.com"
